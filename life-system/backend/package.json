{
  "name": "life-system-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "npm run prisma:generate && tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:railway": "npm run prisma:push && npm run prisma:seed && node dist/server.js",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "test": "npm run prisma:generate && tsx --test tests/**/*.test.ts",
    "prisma:generate": "node scripts/prisma-command.mjs generate",
    "prisma:push": "node scripts/prisma-command.mjs db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.23",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
